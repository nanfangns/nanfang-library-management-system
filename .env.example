# Optional application URL for metadata and deployment previews.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database driver: sqlite, turso, or mysql.
DATABASE_DRIVER="sqlite"

# SQLite can be omitted locally and will default to ./data/library.db.
# For Turso, set this to your remote libsql URL such as:
# DATABASE_URL="libsql://your-database-name-your-org.turso.io"
DATABASE_URL=""

# Turso auth token is only required when DATABASE_DRIVER="turso".
DATABASE_AUTH_TOKEN=""

# MySQL settings are only used when DATABASE_DRIVER="mysql".
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DATABASE="nanfang_library"
MYSQL_SSL="false"

# Optional Open Library request identification.
OPEN_LIBRARY_APP_NAME="nanfang-library-management-system"
OPEN_LIBRARY_CONTACT_EMAIL=""
